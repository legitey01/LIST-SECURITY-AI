# OpenRouter API Key (sk-or-...)
OPENROUTER_API_KEY=your-api-key

# Anthropic API Key (Required for SDK init, set to "router-mode" when using OpenRouter)
ANTHROPIC_API_KEY=router-mode

# Default Model Selection (1, 2, or 3)
# 1: openrouter/healer-alpha
# 2: nvidia/nemotron-3-super-120b-a12b:free
# 3: openrouter/hunter-alpha
AI=1
